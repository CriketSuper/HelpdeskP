# Backup configuration for Helpdesk shell scripts.
# Copy this file to backup.env and adjust the values for your server.

BACKUP_MODE=docker
BACKUP_ROOT=/srv/backups/helpdesk
PROJECT_ROOT=/srv/Helpdesk

# Docker mode settings
COMPOSE_FILE=/srv/Helpdesk/docker-compose.yml
COMPOSE_PROJECT_NAME=helpdesk
DB_SERVICE_NAME=db
WEB_SERVICE_NAME=web
MEDIA_PATH_IN_CONTAINER=/app/Helpdesk/media
LOGS_PATH_IN_CONTAINER=/app/Helpdesk/logs

# Host mode settings
MEDIA_DIR=/srv/Helpdesk/Helpdesk/media
LOGS_DIR=/srv/Helpdesk/Helpdesk/logs
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=helpdesk
POSTGRES_USER=helpdesk
POSTGRES_PASSWORD=change-me

# Cleanup policy
RETENTION_DAYS=30
